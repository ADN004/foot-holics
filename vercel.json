{
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/universal-player.html",
      "destination": "/not-found"
    },
    {
      "source": "/TEMPLATE-event.html",
      "destination": "/not-found"
    }
  ]
}
